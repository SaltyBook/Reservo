<UserControl x:Class="Reservo.Views.StatisticView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Reservo.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Text="Statistik Mieterdaten"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />
            <TextBlock Text="Zeigt dir Statistiken zu den Mieterdaten."
                       Margin="0,4,0,0"
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextSecondary}" />
        </StackPanel>

        <TabControl Grid.Row="2"
                    Style="{StaticResource ModernTabControlStyle}"
                    ItemContainerStyle="{StaticResource ModernTabItemStyle}">

            <!-- Mieter -->
            <TabItem Header="Mieter">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ComboBox Grid.Row="0"
                              Width="180"
                              HorizontalAlignment="Left"
                              Margin="10"
                              ItemsSource="{Binding StatisticData}"
                              SelectedItem="{Binding SelectedStatisticData, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Grid Grid.Row="2"
                          Margin="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Buchungen -->
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Buchungen"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedStatisticData.AllReservations}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>

                        <!-- Gäste -->
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Gäste"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedStatisticData.AllGuests}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>

                        <!-- Nächte -->
                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Nächte (Gruppen)"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedStatisticData.AllNights}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>

                        <!-- Gäste-Nächte -->
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Gäste-Nächte"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedStatisticData.AllGuestsNights}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>

                        <!-- Durchschnitt Gruppe -->
                        <Border Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ø Gruppengröße"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedStatisticData.AverageGroupSize}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>

                        <!-- Durchschnitt Nächte -->
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ø Nächte"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedStatisticData.AverageNightCount}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="3"
                          Margin="10"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Bottom">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock  Grid.Row="0"
                                    Text="Feiertage"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Margin="10"
                                    Foreground="{StaticResource Brush.TextPrimary}" />

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding PublicHolidays}"
                                 Margin="10"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 IsHitTestVisible="False">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock Text="{Binding Key, StringFormat={}{0:dd.MM.yyyy}}"/>

                                        <TextBlock Text="{Binding Value}"
                                                   Margin="10,0,0,0" />

                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Stunden -->
            <TabItem Header="Stunden">
                <Border Margin="0,8,0,0"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                    </Grid>
                </Border>
            </TabItem>
            
        </TabControl>
    </Grid>
</UserControl>
