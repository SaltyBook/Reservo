<UserControl x:Class="Reservo.Views.StatisticView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Reservo.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Text="Statistik Mietverwaltung"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />
            <TextBlock Text="Übersicht über Buchungen, Gäste, Auslastung und Stunden."
                       Margin="0,4,0,0"
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextSecondary}" />
        </StackPanel>

        <TabControl Grid.Row="2"
                    Style="{StaticResource ModernTabControlStyle}"
                    ItemContainerStyle="{StaticResource ModernTabItemStyle}">

            <!-- Mieter -->
            <TabItem Header="Mieter">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="15" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ComboBox Grid.Row="0"
                              Width="180"
                              HorizontalAlignment="Left"
                              Margin="10"
                              ItemsSource="{Binding StatisticData}"
                              SelectedItem="{Binding SelectedStatisticData, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- STATISTIK CARDS -->
                    <UniformGrid Grid.Row="1"
                                 Rows="2"
                                 Columns="4">

                        <!-- Buchungen -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Buchungen"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.AllReservations}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                        <!-- Gäste -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Gäste"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.AllGuests}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                        <!-- Nächte -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Nächte"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.AllNights}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                        <!-- Ø Aufenthalt -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Ø Aufenthalt"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.AverageNightCount}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                        <!-- Gesamtsumme -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Gesamtsumme"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.TotalAmount, StringFormat={}{0:C}}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                        <!-- Gesamtsumme -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Ø Gruppengröße"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.AverageGroupSize}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                        <!-- Gäste-Nächte -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Gäste-Nächte"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.AllGuestsNights}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                        <!-- Gruppe über 27 -->
                        <Border Style="{StaticResource DashboardCardStyle}">
                            <StackPanel>

                                <TextBlock Text="Gruppe über 27"
                                           Style="{StaticResource DashboardCardTitle}" />

                                <TextBlock Text="{Binding SelectedStatisticData.GroupCheckCount}"
                                           Style="{StaticResource DashboardCardValue}" />

                            </StackPanel>
                        </Border>

                    </UniformGrid>


                    <!-- UNTERER BEREICH -->
                    <Grid Grid.Row="3">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <!-- Feiertage -->
                        <Border Grid.Column="0"
                                Style="{StaticResource DashboardCardStyle}">

                            <StackPanel>

                                <TextBlock Text="Feiertage"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"
                                           Foreground="{StaticResource Brush.TextPrimary}" />

                                <ItemsControl ItemsSource="{Binding PublicHolidays}">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Grid Margin="0,4">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Key, StringFormat={}{0:dd.MM.yy}}"
                                                           Foreground="{StaticResource Brush.TextSecondary}" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Value}"
                                                           Foreground="{StaticResource Brush.TextPrimary}" />

                                            </Grid>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </StackPanel>

                        </Border>


                        <!-- INFOS -->
                        <Border Grid.Column="1"
                                Style="{StaticResource DashboardCardStyle}">

                            <StackPanel>

                                <TextBlock Text="Infos &amp; Auslastung"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"
                                           Foreground="{StaticResource Brush.TextPrimary}" />

                                <StackPanel Margin="0,6">
                                    <TextBlock Text="DIE WERTE HIER SIND NUR TEMPORÄR UND STATISCH!"
                                               FontSize="14" />
                                </StackPanel>

                                <StackPanel Margin="0,6">
                                    <TextBlock Text="• Noch 12 freie Wochenenden"
                                               FontSize="14" />
                                </StackPanel>

                                <StackPanel Margin="0,6">
                                    <TextBlock Text="• August fast ausgebucht"
                                               FontSize="14" />
                                </StackPanel>

                                <StackPanel Margin="0,6">
                                    <TextBlock Text="• Ø Gruppengröße: 5 Gäste"
                                               FontSize="14" />
                                </StackPanel>

                                <StackPanel Margin="0,6">
                                    <TextBlock Text="• Beste Auslastung im Juli"
                                               FontSize="14" />
                                </StackPanel>

                                <StackPanel Margin="0,6">
                                    <TextBlock Text="• Osterwochenende noch frei"
                                               FontSize="14" />
                                </StackPanel>

                            </StackPanel>

                        </Border>

                    </Grid>


                    <!-- FOOTER -->
                    <Border Grid.Row="5"
                            Padding="12"
                            CornerRadius="10"
                            Background="{StaticResource Brush.SurfaceSecondary}">

                        <TextBlock Text="Letzte Aktualisierung: 11.05.2026"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.TextSecondary}" />

                    </Border>
                </Grid>
            </TabItem>

            <!-- Stunden -->
            <TabItem Header="Stunden">

                <Border Margin="0,8,0,0"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- HEADER -->
                        <Grid Grid.Row="0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>

                                <TextBlock Text="Mitarbeiterstunden"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}" />

                                <TextBlock Text="Arbeitsstunden pro Monat verwalten."
                                           Margin="0,4,0,0"
                                           FontSize="13"
                                           Foreground="{StaticResource Brush.TextSecondary}" />

                            </StackPanel>

                            <!-- BUTTONS -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">

                                <Button Content="+ Mitarbeiter"
                                        Width="130"
                                        Height="38"
                                        Margin="0,0,10,0"
                                        Command="{Binding AddEmployeeCommand}" />

                                <Button Content="Löschen"
                                        Width="100"
                                        Height="38"
                                        Command="{Binding RemoveEmployeeCommand}" />

                            </StackPanel>

                        </Grid>

                        <!-- TABELLE -->
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding Employees}"
                                  SelectedItem="{Binding SelectedEmployee}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ColumnHeaderHeight="45">

                            <DataGrid.Columns>

                                <!-- NAME -->
                                <DataGridTextColumn Header="Mitarbeiter"
                                                    Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="180" />

                                <!-- MONATE -->
                                <DataGridTextColumn Header="Jan"
                                                    Binding="{Binding January, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Feb"
                                                    Binding="{Binding February, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Mär"
                                                    Binding="{Binding March, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Apr"
                                                    Binding="{Binding April, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Mai"
                                                    Binding="{Binding May, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Jun"
                                                    Binding="{Binding June, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Jul"
                                                    Binding="{Binding July, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Aug"
                                                    Binding="{Binding August, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Sep"
                                                    Binding="{Binding September, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Okt"
                                                    Binding="{Binding October, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Nov"
                                                    Binding="{Binding November, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Dez"
                                                    Binding="{Binding December, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />

                                <!-- SUMME -->
                                <DataGridTextColumn Header="Gesamt"
                                                    Binding="{Binding TotalHours}"
                                                    Width="100"
                                                    IsReadOnly="True" />

                            </DataGrid.Columns>

                        </DataGrid>

                        <!-- SUMMENZEILE -->
                        <Border Grid.Row="3"
                                Margin="0,10,0,0"
                                Padding="10"
                                CornerRadius="10"
                                Background="{StaticResource Brush.SurfaceSecondary}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />

                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="70" />

                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Gesamt"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding HoursSummary.January}" />

                                <TextBlock Grid.Column="2"
                                           Text="{Binding HoursSummary.February}" />

                                <TextBlock Grid.Column="3"
                                           Text="{Binding HoursSummary.March}" />

                                <TextBlock Grid.Column="4"
                                           Text="{Binding HoursSummary.April}" />

                                <TextBlock Grid.Column="5"
                                           Text="{Binding HoursSummary.May}" />

                                <TextBlock Grid.Column="6"
                                           Text="{Binding HoursSummary.June}" />

                                <TextBlock Grid.Column="7"
                                           Text="{Binding HoursSummary.July}" />

                                <TextBlock Grid.Column="8"
                                           Text="{Binding HoursSummary.August}" />

                                <TextBlock Grid.Column="9"
                                           Text="{Binding HoursSummary.September}" />

                                <TextBlock Grid.Column="10"
                                           Text="{Binding HoursSummary.October}" />

                                <TextBlock Grid.Column="11"
                                           Text="{Binding HoursSummary.November}" />

                                <TextBlock Grid.Column="12"
                                           Text="{Binding HoursSummary.December}" />

                                <TextBlock Grid.Column="13"
                                           Text="{Binding HoursSummary.Total}"
                                           FontWeight="SemiBold" />

                            </Grid>

                        </Border>

                    </Grid>

                </Border>

            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
