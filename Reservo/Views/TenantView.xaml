<UserControl x:Class="Reservo.Views.TenantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Reservo.Views"
             xmlns:behavior="clr-namespace:Reservo.Behavior"
             xmlns:classes="clr-namespace:Reservo.Classes"
             xmlns:vm="clr-namespace:Reservo.ViewModels"
             xmlns:models="clr-namespace:Reservo.Models"
             xmlns:inf="clr-namespace:Reservo.Infrastructure"
             xmlns:converters="clr-namespace:Reservo.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:LongDateFormatConverter x:Key="LongDateFormat" />
        <converters:ShortDateFormatConverter x:Key="ShortDateFormat" />
        <converters:EuroFormatConverter x:Key="EuroFormat" />
        <converters:IsPastConverter x:Key="IsPast" />
        <converters:IsCanceledConverter x:Key="IsCanceled" />
        <converters:NullVisibilityConverter x:Key="NullVisibility" />
        <Style x:Key="ModernMenuItemStyle"
               TargetType="MenuItem">
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="Padding"
                    Value="2" />
            <Setter Property="Margin"
                    Value="2" />
            <Setter Property="Foreground"
                    Value="#111827" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="LightSteelBlue" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TabControl Grid.Row="1"
                    ItemsSource="{Binding Workbooks}"
                    SelectedItem="{Binding SelectedWorkbook}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <DataGrid behavior:DataGridColumnOrderBehavior.Enable="True"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Entries}"
                              SelectedItem="{Binding SelectedEntry}"
                              Margin="10"
                              GridLinesVisibility="All"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              VirtualizingPanel.CacheLength="2"
                              VirtualizingPanel.CacheLengthUnit="Page"
                              ScrollViewer.CanContentScroll="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background"
                                        Value="#EEF0EB" />
                                <Style.Triggers>
                                    <!-- Past -->
                                    <DataTrigger Binding="{Binding Departure, Converter={StaticResource IsPast}}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#CCCCCC" />
                                    </DataTrigger>
                                    <!-- Canceled -->
                                    <DataTrigger Binding="{Binding Canceled}"
                                                 Value="True">
                                        <Setter Property="Background"
                                                Value="#FFCDD2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="#284B63" />
                                <Setter Property="Foreground"
                                        Value="#FFFFFF" />
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="Padding"
                                        Value="6" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu Background="#FFFFFF"
                                         BorderBrush="#E5E7EB"
                                         BorderThickness="1"
                                         Padding="5"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Hinzufügen"
                                          Command="{Binding AddEntryCommand}"
                                          Style="{StaticResource ModernMenuItemStyle}" />
                                <MenuItem Header="Löschen"
                                          Command="{Binding DeleteEntryCommand}"
                                          Style="{StaticResource ModernMenuItemStyle}" />
                                <Separator />
                                <MenuItem Header="Reservierung"
                                          Command="{Binding CreateReservationCommand}"
                                          Style="{StaticResource ModernMenuItemStyle}" />
                                <MenuItem Header="Rechnung"
                                          Command="{Binding CreateInvoiceCommand}"
                                          Style="{StaticResource ModernMenuItemStyle}" />
                                <Separator />
                                <MenuItem Header="E-Mail Reservierung"
                                          Command="{Binding CreateReservationEmailCommand}"
                                          Style="{StaticResource ModernMenuItemStyle}" />
                                <MenuItem Header="E-Mail Rechnung"
                                          Command="{Binding CreateInvoiceEmailCommand}"
                                          Style="{StaticResource ModernMenuItemStyle}" />
                                <Separator />
                                <MenuItem Header="Notiz erstellen"
                                          Command="{Binding OpenNoteCommand}"
                                          Style="{StaticResource ModernMenuItemStyle}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn  IsReadOnly="True"
                                                 Header="ID"
                                                 Binding="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="SizeToHeader"
                                                 CanUserReorder="False"
                                                 CanUserResize="False" />
                            <behavior:OneClickDataGridTemplateColumn Header="Gruppe"
                                                                     Width="Auto">
                                <behavior:OneClickDataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <!-- normaler Zellinhalt -->
                                            <TextBlock Text="{Binding GroupName}"
                                                       Width="Auto" />
                                            <!-- kleiner Excel-Marker -->
                                            <ToggleButton x:Name="NoteButton"
                                                          Width="8"
                                                          Height="8"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Top"
                                                          Background="Red"
                                                          Cursor="Hand"
                                                          IsChecked="{Binding IsNoteOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ToggleButton.Visibility>
                                                    <MultiBinding Converter="{StaticResource NullVisibility}">
                                                        <Binding Path="Note" />
                                                        <Binding Path="IsNoteOpen" />
                                                    </MultiBinding>
                                                </ToggleButton.Visibility>
                                            </ToggleButton>
                                            <!-- Popup direkt innerhalb ToggleButton -->
                                            <Popup Placement="Right"
                                                   PlacementTarget="{Binding ElementName=NoteButton}"
                                                   StaysOpen="True"
                                                   AllowsTransparency="True"
                                                   IsOpen="{Binding IsChecked, ElementName=NoteButton, Mode=TwoWay}">
                                                <Border Background="#FFFFE1"
                                                        BorderBrush="#C0C0C0"
                                                        BorderThickness="1"
                                                        Padding="6"
                                                        Width="240">
                                                    <TextBox Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="80" />
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DataTemplate>
                                </behavior:OneClickDataGridTemplateColumn.CellTemplate>
                                <behavior:OneClickDataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding GroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </behavior:OneClickDataGridTemplateColumn.CellEditingTemplate>
                            </behavior:OneClickDataGridTemplateColumn>
                            <DataGridTextColumn Header="Anzahl Gäste"
                                                Binding="{Binding GuestCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="SizeToHeader" />
                            <DataGridTextColumn Header="Anrede"
                                                Binding="{Binding Salutation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="SizeToHeader" />
                            <DataGridTextColumn Header="Vorname"
                                                Binding="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="120" />
                            <DataGridTextColumn Header="Nachname"
                                                Binding="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="120" />
                            <DataGridTextColumn Header="Straße"
                                                Binding="{Binding Street, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="Ort"
                                                Binding="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto" />
                            <DataGridTemplateColumn Header="Anreise"
                                                    Width="170"
                                                    SortMemberPath="Arrival">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Arrival, Converter={StaticResource LongDateFormat}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding Arrival, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Abreise"
                                                    Width="170"
                                                    SortMemberPath="Departure">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Departure, Converter={StaticResource LongDateFormat}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding Departure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Nächte"
                                                Binding="{Binding NightCount, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="SizeToHeader" />
                            <DataGridCheckBoxColumn Header="Infoblatt"
                                                    Binding="{Binding InfoSheet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="SizeToHeader" />
                            <DataGridCheckBoxColumn Header="Kalendereintrag"
                                                    Binding="{Binding CalendarEntry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="SizeToHeader" />
                            <DataGridTextColumn Header="Rechnungsnr."
                                                Binding="{Binding InvoiceNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="SizeToHeader" />
                            <DataGridTextColumn Header="Gesamt"
                                                Binding="{Binding Total, Converter={StaticResource EuroFormat}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto" />
                            <DataGridCheckBoxColumn Header="Altersprüfung"
                                                    Binding="{Binding AgeCheck, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="SizeToHeader" />
                            <DataGridCheckBoxColumn Header="Zelt"
                                                    Binding="{Binding Tent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="SizeToHeader" />
                            <DataGridTextColumn Header="Getränke"
                                                Binding="{Binding Drinks, Converter={StaticResource EuroFormat}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="SizeToHeader" />
                            <DataGridTextColumn Header="Letzter Besuch"
                                                Binding="{Binding LastVisit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="SizeToHeader" />
                            <DataGridTemplateColumn Header="Reserviert"
                                                    Width="SizeToHeader"
                                                    SortMemberPath="Reserved">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Reserved, Converter={StaticResource ShortDateFormat}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding Reserved, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridComboBoxColumn Header="Kontakt"
                                                    SelectedItemBinding="{Binding ContactVia, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    ItemsSource="{Binding Source={x:Static inf:ContactValues.All}}" />
                            <DataGridTextColumn Header="Mobil"
                                                Binding="{Binding Mobile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="Festnetz"
                                                Binding="{Binding HomePhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto" />
                            <DataGridTextColumn Header="E-Mail"
                                                Binding="{Binding EMail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto" />
                            <DataGridCheckBoxColumn Header="Storniert"
                                                    Binding="{Binding Canceled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="SizeToHeader" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
        <StatusBar Margin="10"
                   Grid.Row="2"
                   Background="#F3F4F6">
            <StatusBarItem>
                <TextBlock  Text="{Binding EntryCount, StringFormat={}{0} Einträge}"
                            FontWeight="SemiBold" />
            </StatusBarItem>
            <Separator Width="1"
                       HorizontalAlignment="Center" />
            <StatusBarItem>
                <TextBlock  Text="{Binding PastEntryCount, StringFormat={}{0} Vergangen}"
                            FontWeight="SemiBold" />
            </StatusBarItem>
            <Separator Width="1"
                       HorizontalAlignment="Center" />
            <StatusBarItem>
                <TextBlock  Text="{Binding CanceledEntryCount, StringFormat={}{0} Storniert}"
                            FontWeight="SemiBold" />
            </StatusBarItem>
            <Separator Width="1"
                       HorizontalAlignment="Center" />
            <StatusBarItem>
                <TextBlock  Text="{Binding SelectedWorkbook.SelectedEntry.GroupName}"
                            FontWeight="SemiBold" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
