<UserControl x:Class="Reservo.Views.TenantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behavior="clr-namespace:Reservo.Behavior"
             xmlns:converters="clr-namespace:Reservo.Converters"
             xmlns:inf="clr-namespace:Reservo.Infrastructure"
             xmlns:views="clr-namespace:Reservo.Views"
             mc:Ignorable="d"
             PreviewKeyDown="UserControl_PreviewKeyDown"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>
        <converters:LongDateFormatConverter x:Key="LongDateFormat" />
        <converters:ShortDateFormatConverter x:Key="ShortDateFormat" />
        <converters:EuroFormatConverter x:Key="EuroFormat" />
        <converters:IsPastConverter x:Key="IsPast" />
        <converters:NullVisibilityMultiConverter x:Key="NullMultiVisibility" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="CVJM Freizeit- und Bildungsstätte Niederdieten"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />
            <TextBlock Text="Verwaltung von Reservierungen, Gästen und Buchungen"
                       Margin="0,4,0,0"
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextSecondary}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="2"
                        ItemsSource="{Binding Workbooks}"
                        SelectedItem="{Binding SelectedWorkbook}"
                        Style="{StaticResource ModernTabControlStyle}"
                        ItemContainerStyle="{StaticResource ModernTabItemStyle}">

                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <DataGrid behavior:DataGridColumnOrderBehavior.Enable="True"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          ItemsSource="{Binding Entries}"
                                          SelectedItem="{Binding SelectedEntry}"
                                          Margin="0"
                                          HeadersVisibility="Column"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          VirtualizingPanel.CacheLength="2"
                                          VirtualizingPanel.CacheLengthUnit="Page"
                                          VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Style="{StaticResource ModernDataGridStyle}"
                                          CellStyle="{StaticResource ModernDataGridCellStyle}"
                                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}">

                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow"
                                               BasedOn="{StaticResource ModernDataGridRowStyle}">
                                            <Style.Triggers>

                                                <DataTrigger Binding="{Binding Offer}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource Brush.RowOffer}" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding StayInfo.Departure, Converter={StaticResource IsPast}}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource Brush.RowPast}" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding Canceled}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource Brush.RowCanceled}" />
                                                </DataTrigger>

                                                <Trigger Property="IsSelected"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource Brush.AccentSoftStrong}" />
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource Brush.TextPrimary}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.ContextMenu>
                                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}"
                                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Hinzufügen"
                                                      Command="{Binding AddEntryCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                            <MenuItem Header="Löschen"
                                                      Command="{Binding DeleteEntryCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                            <Separator />
                                            <MenuItem Header="Reservierung"
                                                      Command="{Binding CreateReservationCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                            <MenuItem Header="Rechnung"
                                                      Command="{Binding CreateInvoiceCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                            <Separator />
                                            <MenuItem Header="E-Mail Reservierung"
                                                      Command="{Binding CreateReservationEmailCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                            <MenuItem Header="E-Mail Rechnung"
                                                      Command="{Binding CreateInvoiceEmailCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                            <Separator />
                                            <MenuItem Header="Kalendereintrag erstellen"
                                                      Command="{Binding CreateCalendarEntryCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                            <Separator />
                                            <MenuItem Header="Notiz erstellen"
                                                      Command="{Binding OpenNoteCommand}"
                                                      Style="{StaticResource ModernMenuItemStyle}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"
                                                            IsReadOnly="True"
                                                            Binding="{Binding Id}"
                                                            Width="SizeToHeader"
                                                            CanUserReorder="False"
                                                            CanUserResize="False" />

                                        <behavior:OneClickDataGridTemplateColumn Header="Gruppe"
                                                                                 Width="Auto">
                                            <behavior:OneClickDataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock Text="{Binding GuestInfo.GroupName}" />

                                                        <ToggleButton x:Name="NoteButton"
                                                                      Width="10"
                                                                      Height="10"
                                                                      HorizontalAlignment="Right"
                                                                      VerticalAlignment="Top"
                                                                      Background="{StaticResource Brush.Accent}"
                                                                      BorderThickness="0"
                                                                      Cursor="Hand"
                                                                      IsChecked="{Binding IsNoteOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <ToggleButton.Visibility>
                                                                <MultiBinding Converter="{StaticResource NullMultiVisibility}">
                                                                    <Binding Path="Note" />
                                                                    <Binding Path="IsNoteOpen" />
                                                                </MultiBinding>
                                                            </ToggleButton.Visibility>
                                                        </ToggleButton>

                                                        <Popup Placement="Right"
                                                               PlacementTarget="{Binding ElementName=NoteButton}"
                                                               StaysOpen="True"
                                                               AllowsTransparency="True"
                                                               IsOpen="{Binding IsChecked, ElementName=NoteButton, Mode=TwoWay}">
                                                            <Border Background="{StaticResource Brush.NoteBackground}"
                                                                    BorderBrush="{StaticResource Brush.BorderStrong}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="12"
                                                                    Padding="10"
                                                                    Width="260">
                                                                <TextBox Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         AcceptsReturn="True"
                                                                         TextWrapping="Wrap"
                                                                         MinHeight="90"
                                                                         BorderThickness="0"
                                                                         Background="Transparent" />
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </DataTemplate>
                                            </behavior:OneClickDataGridTemplateColumn.CellTemplate>

                                            <behavior:OneClickDataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding GuestInfo.GroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </behavior:OneClickDataGridTemplateColumn.CellEditingTemplate>
                                        </behavior:OneClickDataGridTemplateColumn>

                                        <DataGridTextColumn Header="Anzahl Gäste"
                                                            Binding="{Binding GuestInfo.GuestCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="SizeToHeader" />
                                        <DataGridTextColumn Header="Anrede"
                                                            Binding="{Binding GuestInfo.Salutation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="SizeToHeader" />
                                        <DataGridTextColumn Header="Vorname"
                                                            Binding="{Binding GuestInfo.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="120" />
                                        <DataGridTextColumn Header="Nachname"
                                                            Binding="{Binding GuestInfo.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="120" />
                                        <DataGridTextColumn Header="Straße"
                                                            Binding="{Binding GuestInfo.Street, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="Auto" />
                                        <DataGridTextColumn Header="Ort"
                                                            Binding="{Binding GuestInfo.Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="Auto" />

                                        <DataGridTemplateColumn Header="Anreise"
                                                                Width="180"
                                                                SortMemberPath="Arrival">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StayInfo.Arrival, Converter={StaticResource LongDateFormat}}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <DatePicker SelectedDate="{Binding StayInfo.Arrival, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Abreise"
                                                                Width="180"
                                                                SortMemberPath="Departure">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StayInfo.Departure, Converter={StaticResource LongDateFormat}}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <DatePicker SelectedDate="{Binding StayInfo.Departure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Nächte"
                                                            Binding="{Binding StayInfo.NightCount, Mode=OneWay}"
                                                            Width="SizeToHeader" />
                                        <DataGridTemplateColumn Header="Infoblatt"
                                                                Width="SizeToHeader">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding StayInfo.InfoSheet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ModernCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Kalendereintrag"
                                                                Width="SizeToHeader">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding StayInfo.CalendarEntry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ModernCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Rechnungsnr."
                                                            Binding="{Binding BillingInfo.InvoiceNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="SizeToHeader" />
                                        <DataGridTextColumn Header="Gesamt"
                                                            Binding="{Binding BillingInfo.Total, Converter={StaticResource EuroFormat}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="Auto" />
                                        <DataGridTemplateColumn Header="Altersprüfung"
                                                                Width="SizeToHeader">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding StayInfo.AgeCheck, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ModernCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Zelt"
                                                                Width="SizeToHeader">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding StayInfo.Tent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ModernCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Getränke"
                                                            Binding="{Binding BillingInfo.Drinks, Converter={StaticResource EuroFormat}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="SizeToHeader" />
                                        <DataGridTextColumn Header="Letzter Besuch"
                                                            Binding="{Binding GuestInfo.LastVisit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="SizeToHeader" />
                                        <DataGridTemplateColumn Header="Reserviert"
                                                                Width="SizeToHeader"
                                                                SortMemberPath="Reserved">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StayInfo.Reserved, Converter={StaticResource ShortDateFormat}}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <DatePicker SelectedDate="{Binding StayInfo.Reserved, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Kontakt"
                                                                Width="165">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding StayInfo.ContactVia}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding Source={x:Static inf:ContactValues.All}}"
                                                              SelectedItem="{Binding StayInfo.ContactVia, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource GridComboBoxStyle}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Mobil"
                                                            Binding="{Binding GuestInfo.Mobile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="Auto" />
                                        <DataGridTextColumn Header="Festnetz"
                                                            Binding="{Binding GuestInfo.HomePhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="Auto" />
                                        <DataGridTextColumn Header="E-Mail"
                                                            Binding="{Binding GuestInfo.EMail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="Auto" />
                                        <DataGridTemplateColumn Header="Angebot"
                                                                Width="SizeToHeader">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding Offer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ModernCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Storniert"
                                                                Width="SizeToHeader">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding Canceled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ModernCheckBoxStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <views:EntryDetailPanel Grid.Column="1"
                                                        DataContext="{Binding}"
                                                        Visibility="{Binding Visibility}" />

                            </Grid>
                        </Border>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <WrapPanel Grid.Row="4">
                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <TextBlock Style="{StaticResource InfoChipTextStyle}"
                               Text="{Binding EntryCount, StringFormat=Einträge: {0}}" />
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <TextBlock Style="{StaticResource InfoChipTextStyle}"
                               Text="{Binding PastEntryCount, StringFormat=Vergangen: {0}}" />
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <TextBlock Style="{StaticResource InfoChipTextStyle}"
                               Text="{Binding CanceledEntryCount, StringFormat=Storniert: {0}}" />
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}">
                    <TextBlock Style="{StaticResource InfoChipTextStyle}"
                               Text="{Binding SelectedWorkbook.SelectedEntry.GuestInfo.GroupName, StringFormat=Auswahl: {0}}" />
                </Border>
            </WrapPanel>
        </Grid>
    </Grid>
</UserControl>