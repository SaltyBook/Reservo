<UserControl x:Class="Reservo.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1200">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Einstellungen"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />
            <TextBlock Text="Verwalte Zugangsdaten, Serverpfade und Integrationen."
                       Margin="0,4,0,0"
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextSecondary}" />
        </StackPanel>

        <TabControl Grid.Row="2"
                    Style="{StaticResource ModernTabControlStyle}"
                    ItemContainerStyle="{StaticResource ModernTabItemStyle}">

            <!-- Datenbank -->
            <TabItem Header="Allgemein">
                <Border Margin="0,8,0,0"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <StackPanel >
                            <TextBlock Text="Datenbank"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Lege den Pfad der Datenbank fest."
                                       Style="{StaticResource SectionDescriptionStyle}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Pfad"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBoxStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <StackPanel>
                                <TextBlock Text="Kalender"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Lege die Kalender-ID fest."
                                           Style="{StaticResource SectionDescriptionStyle}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Kalender-ID"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding CalendarID, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBoxStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       Text="Die Zugangsdaten werden auf dem Server gespeichert." />
                            
                            <Button Grid.Column="1"
                                    Content="Speichern"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveGeneralCommand}" />
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- E-Mail -->
            <TabItem Header="E-Mail">
                <Border Margin="0,8,0,0"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="E-Mail Zugangsdaten"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Lege die Zugangsdaten für den Versand von Reservierungen und Rechnungen fest."
                                       Style="{StaticResource SectionDescriptionStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Benutzername"
                                       Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Passwort"
                                       Style="{StaticResource FormLabelStyle}" />
                            <PasswordBox x:Name="MailPasswordBox"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         PasswordChar="*"
                                         Style="{StaticResource ModernPasswordBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="6">
                            <TextBlock Text="SMTP-Server"
                                       Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="8">
                            <TextBlock Text="Port"
                                       Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBoxStyle}" />
                        </StackPanel>

                        <Grid Grid.Row="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       Text="Die Zugangsdaten werden auf dem Server gespeichert." />

                            <Button Grid.Column="1"
                                    Content="Speichern"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveCredentialsCommand}"
                                    CommandParameter="{Binding ElementName=MailPasswordBox, Path=Password}" />
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Server -->
            <TabItem Header="Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Serverdaten -->
                        <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Serverdaten"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Definiere, ob ein Serverpfad verwendet werden soll."
                                               Style="{StaticResource SectionDescriptionStyle}" />
                                </StackPanel>

                                <CheckBox Grid.Row="2"
                                          IsChecked="{Binding UseServer, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ModernCheckBoxStyle}"
                                          Content="Server verwenden" />

                                <StackPanel Grid.Row="4">
                                    <TextBlock Text="Serverpfad"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding ServerPath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Trello -->
                        <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Trello Daten"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="API-Zugang für die Trello-Integration."
                                               Style="{StaticResource SectionDescriptionStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="API Key"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding TrelloApiKey, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="4">
                                    <TextBlock Text="API Token"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <PasswordBox PasswordChanged="PasswordBox_ApiTokenChanged"
                                                 PasswordChar="*"
                                                 Style="{StaticResource ModernPasswordBoxStyle}" />
                                </StackPanel>

                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               Text="Änderungen werden erst nach dem Speichern übernommen." />

                                    <Button Grid.Column="1"
                                            Content="Speichern"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SaveServerCommand}" />
                                </Grid>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Server -->
            <TabItem Header="Rechnung">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Rechnungsfaktoren -->
                        <Border Background="{StaticResource Brush.Surface}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="24" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Rechnunsfaktoren"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Lege die Faktoren zur Erstellung von Rechnungen fest."
                                               Style="{StaticResource SectionDescriptionStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Übernachtungen (Grundpreis)"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.BasePrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="4">
                                    <TextBlock Text="Übernachtungen Erwachsene ab 27 Jahre"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.FromTwentySevenPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="6">
                                    <TextBlock Text="Übernachtungen Erwachsene bis 26 Jahre"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.UpToTwentySixPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="8">
                                    <TextBlock Text="Übernachtungen Kinder und Jugendliche bis 17 Jahre"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.UpToSeventeenPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="10">
                                    <TextBlock Text="Tagesgäste pro Tag"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.GuestPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="12">
                                    <TextBlock Text="Tage Heizkosten vom 1.10. – 30.4 und bei Bedarf"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.HeaterPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="14">
                                    <TextBlock Text="Bettwäsche (Leihgebühren)"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.BeddingPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="16">
                                    <TextBlock Text="Maschinen Wäsche waschen"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.LaundryPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="18">
                                    <TextBlock Text="Leihgebühr Faltzelt"
                                           Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.TentPrice, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="20">
                                    <TextBlock Text="Kaminholz (kleine Kiste)"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <TextBox Text="{Binding BillingFactorData.WoodPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </StackPanel>

                                <Grid Grid.Row="22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               Text="Änderungen werden erst nach dem Speichern übernommen." />

                                    <Button Grid.Column="1"
                                            Content="Speichern"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SaveBillingFactorCommand}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>