        </Button>
        <StatusBar Margin="10" Grid.Column="2" Grid.Row="2" Background="#F3F4F6">
            <StatusBarItem>
                <TextBlock  Text="{Binding EntryCount, StringFormat={}{0} Einträge}" FontWeight="SemiBold"/>
            </StatusBarItem>
            <Separator Width="1" Grid.ColumnSpan="2" Grid.Column="0" HorizontalAlignment="Center"/>
            <StatusBarItem>
                <TextBlock  Text="{Binding PastEntryCount, StringFormat={}{0} Vergangen}" FontWeight="SemiBold"/>
            </StatusBarItem>
            <Separator Width="1" Grid.ColumnSpan="2" Grid.Column="0" HorizontalAlignment="Center"/>
            <StatusBarItem>
                <TextBlock  Text="{Binding CanceledEntryCount, StringFormat={}{0} Storniert}" FontWeight="SemiBold"/>
            </StatusBarItem>
            <Separator Width="1" Grid.ColumnSpan="2" Grid.Column="0" HorizontalAlignment="Center"/>
            <StatusBarItem>
                <TextBlock  Text="{Binding SelectedWorkbook.SelectedEntry.GroupName}" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
