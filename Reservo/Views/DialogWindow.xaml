<Window x:Class="Reservo.Views.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="460"
        Title="Dialog"
        Style="{StaticResource DialogWindowStyle}"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   LastChildFill="True">
            <Border x:Name="IconBackground"
                    Width="40"
                    Height="40"
                    CornerRadius="20"
                    Background="{StaticResource Brush.InfoSoft}"
                    Margin="0,0,14,0"
                    VerticalAlignment="Top">
                <Viewbox Width="18"
                         Height="18"
                         Stretch="Uniform">
                    <Path x:Name="IconPath"
                          Fill="{StaticResource Brush.InfoStrong}"
                          Data="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10 10-4.49 10-10S17.51 2 12 2Zm0 15a1.25 1.25 0 1 1 0-2.5A1.25 1.25 0 0 1 12 17Zm1-4h-2V7h2v6Z" />
                </Viewbox>
            </Border>

            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Text="Hinweis"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}" />

                <TextBlock x:Name="MessageText"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="{StaticResource Brush.TextSecondary}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="2"
                Style="{StaticResource FormActionBarContainerStyle}">
            <Grid Style="{StaticResource FormActionBarStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButton"
                        Grid.Column="1"
                        Content="Abbrechen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Click="CancelButton_Click" />

                <Button x:Name="OkButton"
                        Grid.Column="2"
                        Content="OK"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="120"
                        Click="OkButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>