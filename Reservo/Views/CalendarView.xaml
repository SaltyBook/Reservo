<UserControl x:Class="Reservo.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Reservo.Converters"
             xmlns:local="clr-namespace:Reservo.Views"
             xmlns:vm="clr-namespace:Reservo.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <UserControl.Resources>

        <!-- Wochentag-Header -->
        <Style x:Key="WeekdayHeader"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11" />
            <Setter Property="FontWeight"
                    Value="Medium" />
            <Setter Property="Foreground"
                    Value="#B4B2A9" />
            <Setter Property="HorizontalAlignment"
                    Value="Center" />
            <Setter Property="Padding"
                    Value="0,6" />
        </Style>

        <!-- Tageszahl -->
        <Style x:Key="DayNumber"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Foreground"
                    Value="#888780" />
            <Setter Property="Margin"
                    Value="0,0,0,3" />
        </Style>

        <!-- Belegungs-Balken Basis -->
        <Style x:Key="EntryBarBase"
               TargetType="Border">
            <Setter Property="Height"
                    Value="16" />
            <Setter Property="Margin"
                    Value="0,0,0,2" />
            <Setter Property="CornerRadius"
                    Value="3" />
        </Style>

        <!-- Stat-Karte -->
        <Style x:Key="StatCard"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#F1EFE8" />
            <Setter Property="CornerRadius"
                    Value="6" />
            <Setter Property="Padding"
                    Value="14,10" />
        </Style>

        <!-- Nav-Button -->
        <Style x:Key="NavButton"
               TargetType="Button">
            <Setter Property="Width"
                    Value="30" />
            <Setter Property="Height"
                    Value="30" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0.5" />
            <Setter Property="BorderBrush"
                    Value="#33000000" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#F1EFE8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Farb-Converter für Balken (Blue / Teal / Purple / Coral / Green / Amber) -->
        <converters:BarColorConverter x:Key="BarBg"
                                      Mode="Background" />
        <converters:BarColorConverter x:Key="BarFg"
                                      Mode="Foreground" />

        <!-- DataTemplate: einzelner Balken -->
        <DataTemplate DataType="{x:Type vm:EntryBar}">
            <Border Background="{Binding ColorKey, Converter={StaticResource BarBg}}">
                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource EntryBarBase}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStart}"
                                         Value="True">
                                <Setter Property="CornerRadius"
                                        Value="3,0,0,3" />
                                <Setter Property="Margin"
                                        Value="0,0,-1,2" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEnd}"
                                         Value="True">
                                <Setter Property="CornerRadius"
                                        Value="0,3,3,0" />
                                <Setter Property="Margin"
                                        Value="-1,0,0,2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <!-- Label nur am Start-Tag -->
                <TextBlock FontSize="10"
                           FontWeight="Medium"
                           Padding="5,0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{Binding ColorKey, Converter={StaticResource BarFg}}"
                           Text="{Binding Label}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility"
                                    Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStart}"
                                             Value="True">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- DataTemplate: ein Kalendertag -->
        <DataTemplate DataType="{x:Type vm:CalendarDay}">
            <Border BorderThickness="0,0,0.5,0.5"
                    BorderBrush="#1A000000"
                    MinHeight="72"
                    Padding="5,5,5,3">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWeekend}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#F7F6F1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHoliday}"
                                         Value="True">
                                <Setter Property="Background"
                                        Value="#FDF5E6" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Tageszahl -->
                    <Grid Margin="0,0,0,3">
                        <!-- Normaler Tag -->
                        <TextBlock Text="{Binding DayNumber}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock"
                                       BasedOn="{StaticResource DayNumber}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOtherMonth}"
                                                     Value="True">
                                            <Setter Property="Opacity"
                                                    Value="0.3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Heute-Kreis -->
                        <Border Width="20"
                                Height="20"
                                CornerRadius="10"
                                Background="#2563EB"
                                HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsToday}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding DayNumber}"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Belegungs-Balken -->
                    <ItemsControl ItemsSource="{Binding Bars}" />
                </StackPanel>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Seitenheader -->
            <RowDefinition Height="*" />
            <!-- Kalender-Karte -->
        </Grid.RowDefinitions>

        <!-- Seitenheader (gleicher Stil wie Mieterlisten-Seite) -->
        <StackPanel Grid.Row="0"
                    Margin="32,28,32,20">
            <TextBlock FontSize="22"
                       FontWeight="Medium"
                       Text="Belegungskalender" />
            <TextBlock FontSize="13"
                       Foreground="#888780"
                       Margin="0,3,0,0"
                       Text="Monatliche Übersicht aller Buchungen" />
        </StackPanel>

        <!-- Kalender-Karte -->
        <Border Grid.Row="1"
                Margin="32,0,32,28"
                Background="White"
                CornerRadius="8"
                BorderThickness="0.5"
                BorderBrush="#1A000000">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Header: Navigation + Legende -->
                    <RowDefinition Height="Auto" />
                    <!-- Wochentage -->
                    <RowDefinition Height="*" />
                    <!-- Tage-Grid -->
                    <RowDefinition Height="Auto" />
                    <!-- Statistik-Leiste -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0"
                      Margin="20,16,20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Navigation -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding PreviousMonthCommand}"
                                ToolTip="Vorheriger Monat">
                            <TextBlock Text="‹"
                                       FontSize="16"
                                       Foreground="#444441" />
                        </Button>
                        <TextBlock FontSize="15"
                                   FontWeight="Medium"
                                   Margin="12,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding MonthTitle}" />
                        <Button Style="{StaticResource NavButton}"
                                Command="{Binding NextMonthCommand}"
                                ToolTip="Nächster Monat">
                            <TextBlock Text="›"
                                       FontSize="16"
                                       Foreground="#444441" />
                        </Button>
                    </StackPanel>

                    <!-- Legende -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,14,0">
                            <Border Width="10"
                                    Height="10"
                                    CornerRadius="2"
                                    Background="#B5D4F4"
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center" />
                            <TextBlock FontSize="12"
                                       Foreground="#888780"
                                       Text="Belegt"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,14,0">
                            <Border Width="10"
                                    Height="10"
                                    CornerRadius="2"
                                    Background="#FDF5E6"
                                    BorderBrush="#EFD99A"
                                    BorderThickness="0.5"
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center" />
                            <TextBlock FontSize="12"
                                       Foreground="#888780"
                                       Text="Feiertag"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="10"
                                    Height="10"
                                    CornerRadius="2"
                                    Background="#F7F6F1"
                                    BorderBrush="#D3D1C7"
                                    BorderThickness="0.5"
                                    Margin="0,0,5,0"
                                    VerticalAlignment="Center" />
                            <TextBlock FontSize="12"
                                       Foreground="#888780"
                                       Text="Wochenende"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Wochentage -->
                <Border Grid.Row="1"
                        BorderThickness="0,0.5,0,0.5"
                        BorderBrush="#1A000000">
                    <UniformGrid Columns="7">
                        <TextBlock Style="{StaticResource WeekdayHeader}"
                                   Text="Mo" />
                        <TextBlock Style="{StaticResource WeekdayHeader}"
                                   Text="Di" />
                        <TextBlock Style="{StaticResource WeekdayHeader}"
                                   Text="Mi" />
                        <TextBlock Style="{StaticResource WeekdayHeader}"
                                   Text="Do" />
                        <TextBlock Style="{StaticResource WeekdayHeader}"
                                   Text="Fr" />
                        <TextBlock Style="{StaticResource WeekdayHeader}"
                                   Text="Sa"
                                   Foreground="#E24B4A" />
                        <TextBlock Style="{StaticResource WeekdayHeader}"
                                   Text="So"
                                   Foreground="#E24B4A" />
                    </UniformGrid>
                </Border>

                <!-- Tage -->
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Statistik-Leiste -->
                <Border Grid.Row="3"
                        BorderThickness="0,0.5,0,0"
                        BorderBrush="#1A000000">
                    <UniformGrid Columns="4">
                        <Border BorderThickness="0,0,0.5,0"
                                BorderBrush="#1A000000"
                                Padding="16,12">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="Medium"
                                           Text="{Binding BookingCount}" />
                                <TextBlock FontSize="11"
                                           Foreground="#888780"
                                           Margin="0,1,0,0"
                                           Text="Belegungen" />
                            </StackPanel>
                        </Border>
                        <Border BorderThickness="0,0,0.5,0"
                                BorderBrush="#1A000000"
                                Padding="16,12">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="Medium"
                                           Text="{Binding OccupiedDays}" />
                                <TextBlock FontSize="11"
                                           Foreground="#888780"
                                           Margin="0,1,0,0"
                                           Text="Belegte Tage" />
                            </StackPanel>
                        </Border>
                        <Border BorderThickness="0,0,0.5,0"
                                BorderBrush="#1A000000"
                                Padding="16,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="20"
                                               FontWeight="Medium"
                                               Text="{Binding OccupancyPercent}" />
                                    <TextBlock FontSize="14"
                                               Foreground="#888780"
                                               VerticalAlignment="Bottom"
                                               Margin="2,0,0,2"
                                               Text="%" />
                                </StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="#888780"
                                           Margin="0,1,0,0"
                                           Text="Auslastung" />
                            </StackPanel>
                        </Border>
                        <Border Padding="16,12">
                            <StackPanel>
                                <TextBlock FontSize="20"
                                           FontWeight="Medium"
                                           Text="{Binding FreeWeeks}" />
                                <TextBlock FontSize="11"
                                           Foreground="#888780"
                                           Margin="0,1,0,0"
                                           Text="Freie Wochen" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
