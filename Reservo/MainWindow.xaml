<Window x:Class="Reservo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Reservo.ViewModels"
        xmlns:enums="clr-namespace:Reservo.Enums"
        mc:Ignorable="d"
        Title="Reservo"
        Height="900"
        Width="1440"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        WindowState="Maximized"
        Background="{StaticResource Brush.AppBackground}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.Sidebar}">
            <Grid Margin="16,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Reservo"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextOnDark}" />
                    <TextBlock Text="Verwaltung"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#9CA3AF" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Navigation"
                               Margin="8,0,0,10"
                               FontSize="12"
                               Foreground="#9CA3AF" />

                    <Button Content="Mieterlisten"
                            Command="{Binding ShowTenantCommand}">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenuItem}"
                                                 Value="{x:Static enums:MenuItemType.Tenant}">
                                        <Setter Property="Background"
                                                Value="{StaticResource Brush.SidebarSelected}" />
                                        <Setter Property="Foreground"
                                                Value="White" />
                                        <Setter Property="FontWeight"
                                                Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Statistiken"
                            Command="{Binding ShowSettingsCommand}"
                            IsEnabled="False"
                            Style="{StaticResource SidebarNavButtonStyle}" />

                    <Button Content="Einstellungen"
                            Command="{Binding ShowSettingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource SidebarNavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenuItem}"
                                                 Value="{x:Static enums:MenuItemType.Settings}">
                                        <Setter Property="Background"
                                                Value="{StaticResource Brush.SidebarSelected}" />
                                        <Setter Property="Foreground"
                                                Value="White" />
                                        <Setter Property="FontWeight"
                                                Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3"
                        Padding="8"
                        CornerRadius="10"
                        Background="#1D2128">
                    <Button Command="{Binding FeedBackCommand}"
                            Style="{StaticResource SidebarGhostButtonStyle}"
                            Content="Feedback senden" />
                </Border>
            </Grid>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Column="1"
              Margin="24">
            <Border Grid.Row="2"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0"
                    SnapsToDevicePixels="True">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Border>
        </Grid>
    </Grid>
</Window>