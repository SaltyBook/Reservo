<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Color x:Key="Color.AppBackground">#F5F7FA</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceAlt">#F9FAFB</Color>

    <Color x:Key="Color.Sidebar">#16181D</Color>
    <Color x:Key="Color.SidebarHover">#23262D</Color>
    <Color x:Key="Color.SidebarSelected">#2D5BFF</Color>

    <Color x:Key="Color.TextPrimary">#111827</Color>
    <Color x:Key="Color.TextSecondary">#6B7280</Color>
    <Color x:Key="Color.TextOnDark">#F9FAFB</Color>

    <Color x:Key="Color.Border">#E5E7EB</Color>
    <Color x:Key="Color.BorderStrong">#D1D5DB</Color>

    <Color x:Key="Color.Accent">#2D5BFF</Color>
    <Color x:Key="Color.AccentHover">#1D4ED8</Color>
    <Color x:Key="Color.AccentSoftStrong">#9FB8FF</Color>
    <Color x:Key="Color.AccentSoft">#E8EEFF</Color>

    <Color x:Key="Color.SuccessSoft">#ECFDF3</Color>
    <Color x:Key="Color.WarningSoft">#FFF7ED</Color>
    <Color x:Key="Color.DangerSoft">#FEF2F2</Color>
    <Color x:Key="Color.MutedRow">#F8FAFC</Color>

    <Color x:Key="Color.RowHover">#F8FAFC</Color>
    <Color x:Key="Color.RowPast">#E5E7EB</Color>
    <Color x:Key="Color.RowCanceled">#FEE2E2</Color>
    <Color x:Key="Color.NoteBackground">#FFFBEB</Color>

    <Color x:Key="Color.InfoSoft">#E8EEFF</Color>
    <Color x:Key="Color.InfoStrong">#2D5BFF</Color>

    <Color x:Key="Color.SuccessStrong">#16A34A</Color>

    <Color x:Key="Color.WarningStrong">#D97706</Color>

    <Color x:Key="Color.ErrorSoft">#FEE2E2</Color>
    <Color x:Key="Color.ErrorStrong">#DC2626</Color>
    
</ResourceDictionary>