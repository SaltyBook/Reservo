<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
<Style  x:Key="DashboardCardStyle"
        TargetType="Border">

    <Setter Property="Background"
            Value="{StaticResource Brush.Surface}" />

    <Setter Property="BorderBrush"
            Value="{StaticResource Brush.Border}" />

    <Setter Property="BorderThickness"
            Value="1" />

    <Setter Property="CornerRadius"
            Value="14" />

    <Setter Property="Padding"
            Value="18" />

    <Setter Property="Margin"
            Value="8" />

</Style>


<Style x:Key="DashboardCardTitle"
       TargetType="TextBlock">

    <Setter Property="FontSize"
            Value="13" />

    <Setter Property="Foreground"
            Value="{StaticResource Brush.TextSecondary}" />

</Style>


<Style x:Key="DashboardCardValue"
       TargetType="TextBlock">

    <Setter Property="FontSize"
            Value="30" />

    <Setter Property="FontWeight"
            Value="SemiBold" />

    <Setter Property="Margin"
            Value="0,6,0,0" />

    <Setter Property="Foreground"
            Value="{StaticResource Brush.TextPrimary}" />

</Style>


</ResourceDictionary>